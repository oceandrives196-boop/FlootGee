}

.badge{
    display:inline-block;
    background:#fff;
    color:#A119A8;
    padding:7px 18px;
    border-radius:20px;
    font-size:13px;
    font-weight:bold;
    margin-bottom:15px;
}

.promo h2{
    margin-bottom:15px;
}

.reward{
    font-size:40px;
    font-weight:bold;
    margin-bottom:15px;
}

.promo p{
    line-height:1.8;
}

.countdown{
    margin-top:25px;
    background:rgba(255,255,255,.18);
